generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String        @unique
  Stocks       Stock[]
  Reservations Reservation[]
}

model Warehouse {
  id           String        @id @default(cuid())
  name         String
  location     String
  Stocks       Stock[]
  Reservations Reservation[]
}

model Stock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  total       Int       @default(0)
  reserved    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model Reservation {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      Status    @default(pending)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
}

enum Status {
  pending
  confirmed
  released
}
